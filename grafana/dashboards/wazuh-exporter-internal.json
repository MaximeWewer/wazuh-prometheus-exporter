      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "s"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 11,
      "type": "table",
      "title": "Build info",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 20,
        "y": 18
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "wazuh_exporter_build_info",
          "refId": "A",
